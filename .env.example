# PubMed E-utilities API
# No API key required, but PubMed requests an email for polite usage.
# They may contact you if your script causes unexpected load.
PUBMED_EMAIL=your-real-email@example.com

# LLM (Ollama)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# PostgreSQL
DATABASE_URL=postgresql://your_user:your_password@localhost:5432/paperpulse

# Logging (DEBUG, INFO, WARNING, ERROR — default: INFO)
LOG_LEVEL=INFO

# Hugging Face Hub — set to 1 after the model is downloaded to skip network checks on every run.
# Remove temporarily if you want to pull a fresh model version.
HF_HUB_OFFLINE=1